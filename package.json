{
  "name": "atlas-desktop-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "ATLAS Desktop Assistant foundation built with Electron, Vite, React, and TypeScript.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:main": "tsc electron/main.ts electron/preload.ts --module commonjs --target es2020 --esModuleInterop --skipLibCheck --watch --outDir .",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:main.js && set \"ELECTRON_RUN_AS_NODE=\"&& npx electron .",
    "build": "vite build && npm run build:main",
    "build:main": "tsc electron/main.ts electron/preload.ts --module commonjs --target es2020 --esModuleInterop --skipLibCheck --outDir .",
    "start": "set \"ELECTRON_RUN_AS_NODE=\"&& npx electron ."
  },
  "dependencies": {
    "cesium": "^1.142.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^28.3.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vite-plugin-static-copy": "^3.1.6",
    "wait-on": "^8.0.1"
  }
}
